---
import BaseLayout from '../components/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import HomeSections from '../components/HomeSections.astro';
import seoData from '../data/seo.json';

const meta = seoData.home.es;
const BASE = 'https://www.gixlabs.com';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Gixlabs',
  url: BASE,
  inLanguage: ['es', 'en'],
  description: meta.description,
};
---

<BaseLayout title={meta.title} description={meta.description} slug={meta.slug} alternateSlug={meta.alternateSlug} lang="es" ogImage={meta.ogImage}>
  <Fragment slot="schema">
    <JsonLd schema={websiteSchema} />
  </Fragment>
  <HomeSections lang="es" />
</BaseLayout>

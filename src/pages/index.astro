---
import BaseLayout from '../components/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import HomePage from '../components/HomePage';
import seoData from '../data/seo.json';

const meta = seoData.home.es;
const BASE = 'https://gixlabs.com';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Gixlabs',
  url: BASE,
  inLanguage: ['es', 'en'],
  description: meta.description,
};
---

<BaseLayout title={meta.title} description={meta.description} slug={meta.slug} alternateSlug={meta.alternateSlug} lang="es">
  <Fragment slot="head">
    <JsonLd schema={websiteSchema} />
  </Fragment>
  <HomePage client:load />
</BaseLayout>

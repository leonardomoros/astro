---
import '../styles/global.css';
import ThankYouPage from '../components/ThankYouPage';
import SEO from '../components/SEO.astro';

const BASE = 'https://gixlabs.com';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title="¡Gracias! Agenda tu sesión estratégica | Gixlabs"
      description="Tu mensaje llegó. Reserva ahora tu sesión estratégica gratuita de 30 minutos con el equipo de Gixlabs."
      slug="/gracias/"
      alternateSlug="/en/thank-you/"
      lang="es"
    />
    {/* No indexar esta página */}
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <ThankYouPage client:load />
  </body>
</html>

---
import BaseLayout from '../../components/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import UxUiPage from '../../components/UxUiPage';
import seoData from '../../data/seo.json';
import { uxUiTranslations } from '../../content/uxUiTranslations';

const meta = seoData.uxUi.es;
const BASE = 'https://gixlabs.com';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio',       item: `${BASE}/` },
    { '@type': 'ListItem', position: 2, name: 'Servicios',    item: `${BASE}/servicios/` },
    { '@type': 'ListItem', position: 3, name: 'Diseño UX/UI', item: `${BASE}/servicios/diseno-ux-ui/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Diseño UX/UI',
  description: meta.description,
  provider: { '@type': 'Organization', name: 'Gixlabs', url: BASE },
  url: `${BASE}${meta.slug}`,
  areaServed: ['Venezuela', 'Estados Unidos', 'España'],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: uxUiTranslations.es.faq.items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout title={meta.title} description={meta.description} slug={meta.slug} alternateSlug={meta.alternateSlug} lang="es" ogImage={meta.ogImage}>
  <Fragment slot="head">
    <JsonLd schema={breadcrumb} />
    <JsonLd schema={serviceSchema} />
    <JsonLd schema={faqSchema} />
  </Fragment>
  <UxUiPage client:load />
</BaseLayout>

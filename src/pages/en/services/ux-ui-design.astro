---
import BaseLayout from '../../../components/BaseLayout.astro';
import JsonLd from '../../../components/JsonLd.astro';
import UxUiSections from '../../../components/UxUiSections.astro';
import seoData from '../../../data/seo.json';
import { uxUiTranslations } from '../../../content/uxUiTranslations';

const meta = seoData.uxUi.en;
const BASE = 'https://www.gixlabs.com';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',         item: `${BASE}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Services',     item: `${BASE}/en/services/` },
    { '@type': 'ListItem', position: 3, name: 'UX/UI Design', item: `${BASE}/en/services/ux-ui-design/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'UX/UI Design',
  description: meta.description,
  provider: { '@type': 'Organization', name: 'Gixlabs', url: BASE },
  url: `${BASE}${meta.slug}`,
  areaServed: ['Venezuela', 'United States', 'Spain'],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: uxUiTranslations.en.faq.items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout title={meta.title} description={meta.description} slug={meta.slug} alternateSlug={meta.alternateSlug} lang="en" ogImage={meta.ogImage}>
  <Fragment slot="schema">
    <JsonLd schema={breadcrumb} />
    <JsonLd schema={serviceSchema} />
    <JsonLd schema={faqSchema} />
  </Fragment>
  <UxUiSections lang="en" />
</BaseLayout>

---
import '../../../styles/global.css';
import EmailPage from '../../../components/EmailPage';
import SEO from '../../../components/SEO.astro';
import JsonLd from '../../../components/JsonLd.astro';
import seoData from '../../../data/seo.json';
import { emailMarketingTranslations } from '../../../content/emailMarketingTranslations';

const meta = seoData.emailMarketing.en;
const BASE = 'https://gixlabs.com';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',            item: `${BASE}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Services',        item: `${BASE}/en/services/` },
    { '@type': 'ListItem', position: 3, name: 'Email Marketing', item: `${BASE}/en/services/email-marketing/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Email Marketing',
  description: meta.description,
  provider: { '@type': 'Organization', name: 'Gixlabs', url: BASE },
  url: `${BASE}${meta.slug}`,
  areaServed: ['Venezuela', 'United States', 'Spain'],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: emailMarketingTranslations.en.faq.items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={meta.title}
      description={meta.description}
      slug={meta.slug}
      alternateSlug={meta.alternateSlug}
      lang="en"
    />
    <JsonLd schema={breadcrumb} />
    <JsonLd schema={serviceSchema} />
    <JsonLd schema={faqSchema} />
  </head>
  <body>
    <EmailPage client:load initialLang="en" />
  </body>
</html>

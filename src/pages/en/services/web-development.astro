---
import BaseLayout from '../../../components/BaseLayout.astro';
import JsonLd from '../../../components/JsonLd.astro';
import WebDevPage from '../../../components/WebDevPage';
import seoData from '../../../data/seo.json';
import { webDevTranslations } from '../../../content/webDevTranslations';

const meta = seoData.webDev.en;
const BASE = 'https://gixlabs.com';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',            item: `${BASE}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Services',        item: `${BASE}/en/services/` },
    { '@type': 'ListItem', position: 3, name: 'Web Development', item: `${BASE}/en/services/web-development/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Web Development',
  description: meta.description,
  provider: { '@type': 'Organization', name: 'Gixlabs', url: BASE },
  url: `${BASE}${meta.slug}`,
  areaServed: ['Venezuela', 'United States', 'Spain'],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: webDevTranslations.en.faq.items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout title={meta.title} description={meta.description} slug={meta.slug} alternateSlug={meta.alternateSlug} lang="en" ogImage={meta.ogImage}>
  <Fragment slot="head">
    <JsonLd schema={breadcrumb} />
    <JsonLd schema={serviceSchema} />
    <JsonLd schema={faqSchema} />
  </Fragment>
  <WebDevPage client:load initialLang="en" />
</BaseLayout>

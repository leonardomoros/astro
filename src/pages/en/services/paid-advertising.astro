---
import BaseLayout from '../../../components/BaseLayout.astro';
import JsonLd from '../../../components/JsonLd.astro';
import PaidAdsSections from '../../../components/PaidAdsSections.astro';
import seoData from '../../../data/seo.json';
import { paidAdsTranslations } from '../../../content/paidAdsTranslations';

const meta = seoData.paidAds.en;
const BASE = 'https://www.gixlabs.com';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',             item: `${BASE}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Services',         item: `${BASE}/en/services/` },
    { '@type': 'ListItem', position: 3, name: 'Paid Advertising', item: `${BASE}/en/services/paid-advertising/` },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Paid Advertising',
  description: meta.description,
  provider: { '@type': 'Organization', name: 'Gixlabs', url: BASE },
  url: `${BASE}${meta.slug}`,
  areaServed: ['Venezuela', 'United States', 'Spain'],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: paidAdsTranslations.en.faq.items.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout title={meta.title} description={meta.description} slug={meta.slug} alternateSlug={meta.alternateSlug} lang="en" ogImage={meta.ogImage}>
  <Fragment slot="head">
    <JsonLd schema={breadcrumb} />
    <JsonLd schema={serviceSchema} />
    <JsonLd schema={faqSchema} />
  </Fragment>
  <PaidAdsSections lang="en" />
</BaseLayout>

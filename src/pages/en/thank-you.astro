---
import '../../styles/global.css';
import ThankYouPage from '../../components/ThankYouPage';
import SEO from '../../components/SEO.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title="Thank you! Book your strategy session | Gixlabs"
      description="Your message arrived. Book your free 30-minute strategy session with the Gixlabs team now."
      slug="/en/thank-you/"
      alternateSlug="/gracias/"
      lang="en"
    />
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <ThankYouPage client:load initialLang="en" />
  </body>
</html>

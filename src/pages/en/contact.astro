---
import BaseLayout from '../../components/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import ContactPage from '../../components/ContactPage';
import seoData from '../../data/seo.json';

const meta = seoData.contact.en;
const BASE = 'https://www.gixlabs.com';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home',    item: `${BASE}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: `${BASE}/en/contact/` },
  ],
};

const contactPointSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Gixlabs',
  url: BASE,
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: 'hello@gixlabs.com',
    availableLanguage: ['Spanish', 'English'],
    areaServed: ['Venezuela', 'United States', 'Spain', 'Latin America'],
  },
};
---

<BaseLayout title={meta.title} description={meta.description} slug={meta.slug} alternateSlug={meta.alternateSlug} lang="en" ogImage={meta.ogImage}>
  <Fragment slot="head">
    <JsonLd schema={breadcrumb} />
    <JsonLd schema={contactPointSchema} />
  </Fragment>
  <ContactPage client:idle initialLang="en" />
</BaseLayout>

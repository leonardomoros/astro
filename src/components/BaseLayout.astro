---
import '../styles/global.css';
import SEO from './SEO.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import Analytics from '@vercel/analytics/astro';
import ChatBot from './ChatBot';

interface Props {
  title: string;
  description: string;
  slug: string;
  alternateSlug: string;
  lang: 'es' | 'en';
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, slug, alternateSlug, lang, ogImage, noindex = false } = Astro.props;

const BASE = 'https://www.gixlabs.com';
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Gixlabs',
  url: BASE,
  logo: `${BASE}/logo.png`,
  description: 'Agencia de ingeniería digital especializada en desarrollo web, SEO, email marketing y publicidad pagada para empresas en Latinoamérica y Estados Unidos.',
  email: 'hello@gixlabs.com',
  foundingDate: '2020',
  areaServed: ['Venezuela', 'United States', 'Spain', 'Latin America'],
  serviceType: ['Web Development', 'SEO Strategy', 'Landing Pages', 'Email Marketing', 'Paid Advertising', 'Web Optimization', 'UX/UI Design'],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: 'hello@gixlabs.com',
    availableLanguage: ['Spanish', 'English'],
  },
  sameAs: [],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png?v=2" />
    <link rel="apple-touch-icon" href="/favicon.png?v=2" />
    <meta name="generator" content={Astro.generator} />
    <SEO {title} {description} {slug} {alternateSlug} {lang} {ogImage} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <body>
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != 'dataLayer' ? '&l=' + l : '';
        j.async = true;
        j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, 'script', 'dataLayer', 'GTM-PC79ZK7L');
    </script>
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-PC79ZK7L"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <slot />
    <slot name="schema" />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <ChatBot client:idle />
    <SpeedInsights />
    <Analytics />
  </body>
</html>
